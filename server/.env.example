# xAI (Grok) credentials for the proxy server. Copy to `.env` and fill in.
XAI_API_KEY=your_xai_api_key_here

# Optional overrides
XAI_MODEL=grok-4.3
XAI_STT_MODEL=grok-stt
XAI_BASE_URL=https://api.x.ai/v1
PORT=3001

# --- Paystack payment webhook (optional, enables auto-upgrade to Pro) ---
# Your Paystack secret key (Settings -> API Keys & Webhooks). Used to verify
# the webhook signature.
PAYSTACK_SECRET_KEY=
# Supabase project URL and SERVICE ROLE key (Project Settings -> API).
# The service role key is secret — keep it only here on the server, never in the app.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
