{
  "buildCommand": "npm run web:export",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/welcome/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/welcome/terms.html"
    },
    {
      "source": "/refund",
      "destination": "/welcome/refund.html"
    },
    {
      "source": "/cookies",
      "destination": "/welcome/cookies.html"
    },
    {
      "source": "/data-deletion",
      "destination": "/welcome/data-deletion.html"
    },
    {
      "source": "/support",
      "destination": "/welcome/support.html"
    },
    {
      "source": "/welcome",
      "destination": "/welcome/index.html"
    }
  ]
}
