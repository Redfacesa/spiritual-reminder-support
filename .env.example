# Base URL of the spiritual companion proxy server (see /server).
# Use your computer's LAN IP (e.g. http://192.168.1.20:3001) when running on a physical device.
EXPO_PUBLIC_PROXY_URL=http://localhost:3001

# Supabase project credentials (Project Settings -> API).
# The anon key is safe to ship in the client; Row Level Security protects data.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
