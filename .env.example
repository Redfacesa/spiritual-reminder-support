# Public web/mobile client variables (safe in browser bundle — use EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Local dev: proxy server on your machine. Vercel production: use /api
EXPO_PUBLIC_PROXY_URL=http://localhost:3001

# Private server-only (Vercel Functions / server/) — never EXPO_PUBLIC_
# XAI_API_KEY=
# PAYSTACK_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
